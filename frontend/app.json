{
  "expo": {
    "name": "Page and Frame",
    "slug": "noteflow-project",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "noteflow",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
