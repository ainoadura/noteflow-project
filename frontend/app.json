{
  "expo": {
    "name": "Page and Frame",
    "slug": "noteflow-project",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "noteflow",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pageandframe.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.pageandframe.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
