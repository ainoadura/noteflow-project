{
  "expo": {
    "name": "Page & Frame",
    "slug": "noteflow-project",
    "version": "1.0.0",
    "scheme": "pageandframe",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
